name: Build Android App with Bubblewrap

on:
  push:
    branches: [ main ]

jobs:
  build-apk:
    runs-on: ubuntu-latest

    steps:
    # 1. Check out your web application repository code
    - name: Checkout Repository
      uses: actions/checkout@v4

    # 2. Set up Java Development Kit (Android SDK requires Java)
    - name: Set up JDK 17
      uses: actions/setup-java@v4
      with:
        java-version: '17'
        distribution: 'temurin'

    # 3. Set up Node.js environment
    - name: Set up Node.js
      uses: actions/setup-node@v4
      with:
        node-version: '20'

    # 4. Install Bubblewrap CLI globally
    - name: Install Bubblewrap CLI
      run: npm install -g @bubblewrap/cli

    # 5. Build your web application (if static assets are needed in the runner)
    - name: Install Web Dependencies & Build
      run: |
        npm ci
        npm run build

    # 6. Run Bubblewrap Build
    - name: Build Android Package
      run: |
        # In a CI environment, you must pass keystore credentials via environment variables
        # or use non-interactive commands.
        bubblewrap build
